#!/usr/bin/env bb

(require '[babashka.process :as p]
         '[clojure.java.io :as io]
         '[clojure.string :as str])

(def repo-dir (-> *file* io/file .getParentFile .getCanonicalPath))
(def flake repo-dir)
(def local-host (str/trim (:out (p/sh "hostname"))))

(def red "\033[0;31m")
(def green "\033[0;32m")
(def blue "\033[0;34m")
(def nc "\033[0m")

(defn prefix-stream [stream color name]
  (future
    (with-open [rdr (io/reader stream)]
      (doseq [line (line-seq rdr)]
        (println (str color "[" name "]" nc " " line))))))

(defn rebuild [{:keys [name build-host color]}]
  (let [args (cond-> ["nixos-rebuild" "switch" "--flake" (str flake "#" name) "--sudo"]
               (not= name local-host) (into ["--target-host" name "--build-host" build-host]))
        proc (apply p/process {:out :stream :err :stream} args)
        f-out (prefix-stream (:out proc) color name)
        f-err (prefix-stream (:err proc) color name)]
    {:proc proc :futures [f-out f-err]}))

(println "==> Pulling latest changes...")
(p/shell {:dir repo-dir} "git" "pull")

(let [riva (rebuild {:name "riva" :build-host "riva" :color green})
      watts (rebuild {:name "watts" :build-host "watts" :color blue})
      _ @(p/check (:proc watts))
      ampere (rebuild {:name "ampere" :build-host "watts" :color red})]
  @(p/check (:proc riva))
  @(p/check (:proc ampere))
  (run! deref (mapcat :futures [riva watts ampere])))

(println "==> Done!")
