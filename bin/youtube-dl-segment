#! /usr/bin/env bash

url=$1
start=$2 end=$3

video_format=22 # h.264/AVC
video_meta=$(yt-dlp --dump-json $url)
# video_url=$(jq --raw-output ".formats[] | select(.format_id == \"${video_format}\").url" <<< $video_meta)
video_url=$(<<<$video_meta jq -r '.formats[] | select(.acodec != "none")' | jq -s last | jq .url)

title=$(jq --raw-output '.title' <<< $video_meta)
output_file_name="${title}_${start}-${end}"

noverbose='-hide_banner -loglevel error'

ffmpeg \
  $noverbose \
  -ss $start -to $end \
  -i $video_url \
  -f matroska - \
| ffmpeg -i - \
  $noverbose \
  -c:v libx265 -crf 28 \
  -preset ultrafast \
  -movflags +faststart \
  -f matroska \
  "${output_file_name}.mkv"
